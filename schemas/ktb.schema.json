{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karentonoyan.pl/schemas/ktb.schema.json",
  "title": "KTB benchmark item",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "set",
    "category",
    "difficulty",
    "question",
    "gold_answer",
    "tags",
    "mono"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "set": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "gold_answer": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mono": {
      "type": "string",
      "minLength": 1
    }
  }
}
